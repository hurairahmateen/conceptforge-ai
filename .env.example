# --- Supabase Database & Auth (Required) ---
# Your Supabase Project URL (found in Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"

# Your Supabase Anon Key (found in Project Settings -> API)
# This is safe to expose to the browser and used by the auth client
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# --- AI Providers (Optional but Recommended) ---
# If you don't provide these, the application will force users to input their own keys on the Dashboard Settings page.
# Providing them here gives the application a default rate-limited backend.

# Google Gemini API Key
GEMINI_API_KEY="your-gemini-key-here"

# OpenAI API Key
OPENAI_API_KEY="your-openai-key-here"
